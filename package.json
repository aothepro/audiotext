{
  "name": "audiotext",
  "version": "1.0.0",
  "description": "Convert OGG audio to text using Whisper (local)",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "transcribe": "tsx transcribe.ts",
    "start": "node dist/server.js",
    "dev": "tsx watch server.ts",
    "prestart": "npm run build"
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.4.0",
    "express": "^5.1.0",
    "ffmpeg-static": "^5.2.0",
    "multer": "^2.0.2",
    "wavefile": "^11.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.2.0",
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
